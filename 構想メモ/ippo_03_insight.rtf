function Card(\{ title, children, legend, onLegendClick, activeSeries \}) \{\
  return (\
    <div style=\{\{ background:T.bg, border:`0.5px solid $\{T.border\}`, borderRadius:16, padding:"14px 16px", marginBottom:12 \}\}>\
