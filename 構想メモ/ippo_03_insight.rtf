          <polyline key=\{s.key\} points=\{data.map((d,i)=>`$\{toX(i)\},$\{toY(d[s.key])\}`).join(" ")\}\
            fill="none" stroke=\{s.color\} strokeWidth=\{activeSeries&&activeSeries!==s.key?0.5:1.8\}\
            opacity=\{activeSeries&&activeSeries!==s.key?0.15:0.9\} strokeLinejoin="round" strokeLinecap="round"/>\
        ))\}\
        \{data.length<=7 && series.filter(s=>!activeSeries||activeSeries===s.key).map(s=>\
          data.map((d,i)=><circle key=\{`$\{s.key\}-$\{i\}`\} cx=\{toX(i)\} cy=\{toY(d[s.key])\} r=\{3\} fill=\{s.color\} opacity=\{0.9\}/>)\
        )\}\
      </svg>\
    </div>\
  );\
\}\
