        \{data.length<=7 && data.map((d,i)=><circle key=\{i\} cx=\{toX(i)\} cy=\{toY(d.sleep)\} r=\{3\} fill=\{sleepColor\} opacity=\{0.9\}/>)\}\
      </svg>\
    </div>\
  );\
\}\
\
function ScatterChart(\{ data \}) \{\
  const padL=28,padR=8,padT=10,padB=28, W=260, H=120, innerW=W-padL-padR, innerH=H-padT-padB;\
  const minS=3,maxS=12, toX=s=>padL+((Math.min(Math.max(s,minS),maxS)-minS)/(maxS-minS))*innerW, toY=v=>padT+innerH-((v-1)/4)*innerH;\
  return (\
    <svg width="100%" viewBox=\{`0 0 $\{W\} $\{H\}`\}>\
      \{[1,2,3,4,5].map(t=>(<g key=\{t\}><line x1=\{padL\} y1=\{toY(t)\} x2=\{W-padR\} y2=\{toY(t)\} stroke=\{T.border\} strokeWidth=\{0.5\}/><text x=\{padL-4\} y=\{toY(t)+4\} textAnchor="end" fontSize=\{8\} fill=\{T.textMuted\}>\{t\}</text></g>))\}\
      \{[3,6,9,12].map(s=><text key=\{s\} x=\{toX(s)\} y=\{H-2\} textAnchor="middle" fontSize=\{8\} fill=\{T.textMuted\}>\{s\}h</text>)\}\
      \{data.map((d,i)=><circle key=\{i\} cx=\{toX(d.sleep)\} cy=\{toY(d.amMood)\} r=\{3.5\} fill=\{moodColor\} opacity=\{0.5\}/>)\}\
