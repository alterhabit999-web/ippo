function generateData(days) \{\
  const data = [];\
  for (let i = days-1; i >= 0; i--) \{\
    const d = new Date(); d.setDate(d.getDate()-i);\
    data.push(\{ label:`$\{d.getMonth()+1\}/$\{d.getDate()\}`, mood:Math.round(2+Math.random()*3), energy:Math.round(2+Math.random()*3), stress:Math.round(1+Math.random()*4), sleep:parseFloat((5+Math.random()*4).toFixed(1)), amMood:Math.round(2+Math.random()*3) \});\
  \}\
  return data;\
\}\
const DATA = \{ "7":generateData(7), "30":generateData(30), "all":generateData(90) \};\
const CHART_WIDTH = \{ "7":260, "30":520, "all":900 \};\
const LABEL_STEP  = \{ "7":1,   "30":5,   "all":20  \};\
\
function avg(arr,key)\{ const v=arr.map(d=>d[key]).filter(Boolean); return (v.reduce((a,b)=>a+b,0)/v.length).toFixed(1); \}\
function showLabels(data,period)\{ return data.map((_,i)=>i).filter(i => i % LABEL_STEP[period] === 0 || i === data.length-1); \}\
\
function MoodLineChart(\{ data, activeSeries, period \}) \{\
  const padL=28,padR=12,padT=10,padB=28, W=CHART_WIDTH[period], H=130, innerW=W-padL-padR, innerH=H-padT-padB;\
  const toX=i=>padL+i*(innerW/(data.length-1||1)), toY=v=>padT+innerH-((v-1)/4)*innerH;\
  const series=[\{key:"mood",color:moodColor\},\{key:"energy",color:energyColor\},\{key:"stress",color:stressColor\}];\
  return (\
    <div style=\{\{ overflowX:"auto", WebkitOverflowScrolling:"touch" \}\}>\
      <svg width=\{W\} height=\{H\} style=\{\{ display:"block" \}\}>\
        \{[1,2,3,4,5].map(t=>(\
          <g key=\{t\}>\
            <line x1=\{padL\} y1=\{toY(t)\} x2=\{W-padR\} y2=\{toY(t)\} stroke=\{T.border\} strokeWidth=\{0.5\}/>\
            <text x=\{padL-4\} y=\{toY(t)+4\} textAnchor="end" fontSize=\{8\} fill=\{T.textMuted\}>\{t\}</text>\
          </g>\
        ))\}\
        \{showLabels(data,period).map(i=>(\
          <text key=\{i\} x=\{toX(i)\} y=\{H-2\} textAnchor="middle" fontSize=\{7\} fill=\{T.textMuted\}>\{data[i].label\}</text>\
        ))\}\
